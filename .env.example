# =============================================================================
# Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your values
# Do NOT commit .env.local to version control!

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
# Get this from Railway, Supabase, or your own PostgreSQL host
DATABASE_URL="postgresql://user:password@host:5432/database"

# =============================================================================
# Gemini AI (Google AI Studio)
# =============================================================================
# Get your API key from: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_GEMINI_API_KEY="AIzaSy..."

# =============================================================================
# Riot Games API
# =============================================================================
# Get your API key from: https://developer.riotgames.com/
RIOT_API_KEY="RGAPI-..."

# =============================================================================
# Stripe (Payment Processing)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRO_MONTHLY_PRICE_ID="price_..."
STRIPE_PRO_YEARLY_PRICE_ID="price_..."
STRIPE_TEAM_MONTHLY_PRICE_ID="price_..."
STRIPE_TEAM_YEARLY_PRICE_ID="price_..."

# =============================================================================
# Application URL
# =============================================================================
# Use localhost for development, your domain for production
NEXT_PUBLIC_APP_URL="http://localhost:5173"

# =============================================================================
# Authentication (NextAuth.js)
# =============================================================================
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:5173"

# =============================================================================
# Clerk Authentication (optional alternative)
# =============================================================================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/signup"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# =============================================================================
# Sentry Error Tracking (optional)
# =============================================================================
# Get from: https://sentry.io/settings/
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# =============================================================================
# Vercel (for production deployment)
# =============================================================================
# These are set automatically in Vercel
# VERCEL=""
# VERCEL_URL=""

